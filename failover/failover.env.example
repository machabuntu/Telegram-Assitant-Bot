# Failover watchdog configuration
# Install copies this to /etc/default/ai-assistant-bot-failover (if missing).

# Master server healthcheck (same host/port as healthcheck in bot config.json)
MASTER_HOST=212.69.85.168
MASTER_PORT=18473
HEALTH_PATH=/healthz

# Poll master every N seconds; curl timeout per request
CHECK_INTERVAL=10
REQUEST_TIMEOUT=15

# Local systemd unit to start/stop on standby machine
BOT_SERVICE=ai-assistant-bot
